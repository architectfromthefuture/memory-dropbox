# Copy to `.env` at repo root: `cp .env.example .env`
#
# `docker-compose.yml` sets POSTGRES_HOST / REDIS_HOST / QDRANT_HOST for api + worker
# to Compose service names (postgres, redis, qdrant). Values below apply when you run
# Python or Alembic on the host against published ports, or as defaults inside `.env`.

POSTGRES_DB=memory_dropbox
POSTGRES_USER=memory_dropbox
POSTGRES_PASSWORD=memory_dropbox

# Host-mode tooling (local Python against docker-published ports):
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

REDIS_HOST=localhost
REDIS_PORT=6379

QDRANT_HOST=localhost
QDRANT_PORT=6333

API_PORT=8000

EMBEDDING_DIM=384
QDRANT_COLLECTION=memory_items

LOG_LEVEL=INFO
